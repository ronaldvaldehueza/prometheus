assName=\"card-title\"><i className=\"fas fa-chart-pie\"></i>Project Analytics</strong>\n      </div>\n\n      <div className=\"col-lg-6 col-xl-6\">\n        <Pie data={{\n          labels: ['To do', 'In progress', 'Done', 'Blocked'],\n          datasets: [\n            {\n              label: '# of Votes',\n              data: [todo, inprogress, done, blocked],\n              backgroundColor: [\n                'rgba(255, 99, 132, 0.2)',\n                'rgba(54, 162, 235, 0.2)',\n                'rgba(255, 206, 86, 0.2)',\n                'rgba(111, 111, 86, 0.2)'\n              ],\n              borderColor: [\n                'rgba(255, 99, 132, 1)',\n                'rgba(54, 162, 235, 1)',\n                'rgba(255, 206, 86, 1)',\n                'rgba(111, 111, 86, 1)'\n              ],\n              borderWidth: 1,\n            },\n          ],\n        }} />\n        <br />\n      </div>\n\n\n    </div>\n\n  )\n};\n\nProjectAnalytics.propTypes = {};\n\nProjectAnalytics.defaultProps = {};\n\nexport default ProjectAnalytics;\n","D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\mytask\\Task\\Task.js",["601","602","603","604","605","606","607","608","609","610","611","612","613","614","615","616","617","618","619","620","621","622","623","624","625","626","627","628","629","630"],"D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\project\\ProjectReport\\ProjectReport.js",["631"],"import React, { useState } from 'react';\nimport PropTypes from 'prop-types';\nimport './ProjectReport.css';\nimport { useForm } from 'react-hook-form';\nimport projectValidation from '../../../main/validations/projectValidation';\nimport projectHTTPService from '../../../main/services/projectHTTPService';\n\nconst ProjectReport = () => {\n  const initialState = {\n    status: '',\n    starting_date: '',\n    ending_date: ''\n  }\n  const { register, handleSubmit, errors } = useForm()\n  const [project, setProject] = useState(initialState);\n  const [projectList, setProjectList] = useState([]);\n  const onSubmit = (data) => {\n    projectHTTPService.filterProject(data).then(data => {\n      setProjectList(data.data)\n    })\n  }\n\n  const handleInputChange = event => {\n    const { name, value } = event.target;\n    setProject({ ...project, [name]: value });\n  };\n\n  return (\n    <div className=\"ProjectReport\">\n      <form method=\"POST\" className=\"\" onSubmit={handleSubmit(onSubmit)}>\n\n        <select ref={register({ required: true })} onChange={handleInputChange} value={project.status}\n          name=\"status\" className=\"selectpicker form-control border-0 mb-1 px-4 py-4 rounded shadow\">\n          <option value=\"started\">Non Démarré</option>\n          <option value=\"en cours\">en cours</option>\n          <option value=\"Fini\">Fini</option>\n        </select>\n\n        <div className=\"form-group\">\n          <label>Début<span className=\"text-danger\">*</span></label>\n          <input ref={register({ required: true })} onChange={handleInputChange} value={project.starting_date}\n            type=\"date\" name=\"starting_date\" className=\"form-control datepicker\" />\n          <div className=\"error text-danger\">\n            {errors.starting_date && projectValidation.starting_date}\n          </div>\n        </div>\n\n        <div className=\"form-group\">\n          <label>fin<span className=\"text-danger\">*</span></label>\n          <input ref={register({ required: true })} onChange={handleInputChange} value={project.ending_date}\n            type=\"date\" name=\"ending_date\" className=\"form-control datepicker\" />\n          <div className=\"error text-danger\">\n            {errors.ending_date && projectValidation.ending_date}\n          </div>\n        </div>\n        <button type=\"submit\" id=\"save-form\" className=\"btn btn-success\"><i className=\"fa fa-check\"></i>\n          <font   ><font   > Sauvegarder</font></font></button>\n      </form>\n\n\n      {Array.isArray(projectList) && projectList && \n      projectList.map(item => item.status\n\n      )}\n\n    </div>\n  )\n};\n\nProjectReport.propTypes = {};\n\nProjectReport.defaultProps = {};\n\nexport default ProjectReport;\n","D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\project\\Projects\\Projects.js",["632","633","634","635","636","637","638","639","640","641","642","643","644","645","646","647","648","649","650","651","652"],"D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\task\\Tasks\\Tasks.js",["653","654","655","656","657","658","659","660","661","662","663","664","665","666","667","668","669"],"D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\project\\ProjectKanban\\ProjectKanban.js",["670","671","672"],"D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\task\\TaskReport\\TaskReport.js",["673","674","675"],"import React, { useState } from 'react';\nimport PropTypes from 'prop-types';\nimport './TaskReport.css';\nimport { useForm } from 'react-hook-form';\nimport projectHTTPService from '../../../main/services/projectHTTPService';\n\nconst TaskReport = () => {\n\n  const initialState = {\n    status: '',\n    starting_date: '',\n    ending_date: ''\n  }\n  const { register, handleSubmit, errors } = useForm()\n  const [project, setProject] = useState(initialState);\n  const [projectList, setProjectList] = useState([]);\n  const onSubmit = (data) => {\n    projectHTTPService.filterProject(data).then(data => {\n      setProjectList(data.data)\n    })\n  }\n\n  const handleInputChange = event => {\n    const { name, value } = event.target;\n    setProject({ ...project, [name]: value });\n  };\n\n\n  return (\n    <div className=\"TaskReport\">\n      <form method=\"POST\" className=\"\" onSubmit={handleSubmit(onSubmit)}>\n\n        <select ref={register({ required: true })} onChange={handleInputChange} value={project.status}\n          name=\"status\" className=\"selectpicker form-control border-0 mb-1 px-4 py-4 rounded shadow\">\n          <option value=\"started\">Non Démarré</option>\n          <option value=\"en cours\">en cours</option>\n          <option value=\"Fini\">Fini</option>\n        </select>\n\n        <select ref={register({ required: true })} onChange={handleInputChange} value={project.status}\n          name=\"status\" className=\"selectpicker form-control border-0 mb-1 px-4 py-4 rounded shadow\">\n          <option value=\"started\">High</option>\n          <option value=\"en cours\">low</option>\n          <option value=\"Fini\">normal</option>\n        </select>\n\n        <button type=\"submit\" id=\"save-form\" className=\"btn btn-success\"><i className=\"fa fa-check\"></i>\n          <font   ><font   > Sauvegarder</font></font></button>\n      </form>\n    </div>\n  )\n};\n\nTaskReport.propTypes = {};\n\nTaskReport.defaultProps = {};\n\nexport default TaskReport;\n","D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\project\\ProjectCalendar\\ProjectCalendar.js",["676","677","678","679"],"import React, { useEffect, useRef, useState } from 'react';\nimport PropTypes from 'prop-types';\nimport './ProjectCalendar.css';\nimport FullCalendar from \"@fullcalendar/react\";\nimport dayGridPlugin from \"@fullcalendar/daygrid\";\n\nimport \"@fullcalendar/core/main.css\";\nimport \"@fullcalendar/daygrid/main.css\";\nimport { NavLink } from 'react-router-dom';\nimport projectHTTPService from '../../../main/services/projectHTTPService';\nconst ProjectCalendar = () => {\n\n  const buttonAdd = useRef(null);\n  const [projects, setProjects] = useState([]);\n  const [events, setEvents] = useState([]);\n  useEffect(() => {\n\n    retrieveProjects()\n  }, []);\n\n  const retrieveProjects = () => {\n    const eve = [];\n    //var projects = ProjectTestService.getAll();\n    //setLoading(true)\n    let colors = ['orange', 'blue', 'green', 'yellow', 'red']\n    projectHTTPService.getAllProject().then(res => {\n      for (const item of res.data) {\n        let index = Math.floor(Math.random() * (colors.length - 0 + 1) + 0)\n        eve.push({ title: item.title, start: item.starting_date, end: item.ending_date, color: colors[index] })\n      }\n      setEvents(eve)\n    })\n\n\n  };\n\n\n  return (\n    <div className=\"card\">\n\n      <div className=\"card-header\">\n        <h4><i className=\"menu-icon fa fa-folder\"></i> Projects</h4>\n      </div>\n      <div className=\"card-body\">\n\n        <div className=\"btn-group\">\n          <button type=\"button\" className=\"btn btn-danger btn-sm dropdown-toggle\" data-toggle=\"dropdown\" aria-haspopup=\"true\" aria-expanded=\"false\">\n            <i className=\"menu-icon fa fa-male\"></i>  Switch to\n          </button>\n          <div className=\"dropdown-menu\">\n            <NavLink className=\"dropdown-item\" to=\"/projects\">List view</NavLink>\n            <NavLink className=\"dropdown-item\" to=\"/project-kanban\">Kanban view</NavLink>\n            <NavLink className=\"dropdown-item\" to=\"/calendar\">Calendar view</NavLink>\n            <NavLink className=\"dropdown-item\" to=\"/timeline\" >Gantt view</NavLink>\n          </div>\n        </div>\n        <FullCalendar\n          defaultView=\"dayGridMonth\"\n          plugins={[dayGridPlugin]}\n          events={events}\n        />\n      </div>\n    </div>\n  );\n};\n\nProjectCalendar.propTypes = {};\n\nProjectCalendar.defaultProps = {};\n\nexport default ProjectCalendar;\n","D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\task\\TaskAnalytics\\TaskAnalytics.js",["680","681","682"],"import React, { useEffect, useState } from 'react';\nimport PropTypes from 'prop-types';\nimport './TaskAnalytics.css';\nimport { Pie } from 'react-chartjs-2';\nimport { Chart as ChartJS, ArcElement, Tooltip, Legend } from 'chart.js';\nimport taskHHTPService from '../../../main/services/taskHHTPService';\n\n//import typeSubsHTTPService from '../../../main/services/typeSubsHTTPService';\n\nChartJS.register(ArcElement, Tooltip, Legend);\nconst TaskAnalytics = () => {\n  const [categories, setCategories] = useState([]);\n  const [todo, setTodo] = useState(0);\n  const [inprogress, setInprogress] = useState(0);\n  const [completed, setCompleted] = useState(0);\n  const [inreview, setInreview] = useState(0);\n\n\n  useEffect(() => {\n\n    taskHHTPService.getTodo().then(data => {\n      setTodo(data.data.todo)\n    })\n    taskHHTPService.getInprogress().then(data => {\n      setInprogress(data.data.inprogress)\n    })\n    taskHHTPService.getCompleted().then(data => {\n      setCompleted(data.data.completed)\n    })\n    taskHHTPService.getinreview().then(data => {\n      setInreview(data.data.inreview)\n    })\n\n  });\n  return (\n    <div className=\"card\">\n\n      <div className=\"card-header\">\n        <strong className=\"card-title\"><i className=\"fas fa-chart-pie\"></i>Task Analytics</strong>\n      </div>\n\n      <div className=\"col-lg-6 col-xl-6\">\n        <Pie data={{\n          labels: ['To do', 'In Progress', 'Completed', 'In Review'],\n          datasets: [\n            {\n              label: '# of Votes',\n              data: [todo, inprogress, completed, inreview],\n              backgroundColor: [\n                'rgba(255, 99, 132, 0.2)',\n                'rgba(54, 162, 235, 0.2)',\n                'rgba(255, 206, 86, 0.2)',\n                'rgba(111, 111, 86, 0.2)'\n              ],\n              borderColor: [\n                'rgba(255, 99, 132, 1)',\n                'rgba(54, 162, 235, 1)',\n                'rgba(255, 206, 86, 1)',\n                'rgba(111, 111, 86, 0.2)'\n              ],\n              borderWidth: 1,\n            },\n          ],\n        }} />\n        <br />\n      </div>\n\n\n    </div>\n\n  )\n};\n\nTaskAnalytics.propTypes = {};\n\nTaskAnalytics.defaultProps = {};\n\nexport default TaskAnalytics;\n","D:\\WORKS25\\ShakeWell\\Prometheus\\frontend\\src\\modules\\task\\task-kanban\\task-kanban.js",["683","684","685","686","687","688","689","690","691","692","693","